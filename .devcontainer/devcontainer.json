{
  "name": "alfredgamulo",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "mounts": [
    {
      "source": "alfredgamulo-node-modules",
      "target": "/workspaces/alfredgamulo/node_modules",
      "type": "volume"
    },
    {
      "source": "${localEnv:HOME}/.aws",
      "target": "/home/node/.aws",
      "type": "bind",
      "readonly": true
    },
    {
      "source": "${localEnv:HOME}/.ssh",
      "target": "/home/node/.ssh",
      "type": "bind",
      "readonly": true
    }
  ],
  "postCreateCommand": "[ -f package.json ] && sudo chown -R node:node /workspaces/alfredgamulo/node_modules && npm install || true",
  "forwardPorts": [4321, 4322],
  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "hashicorp.terraform",
        "tamasfe.even-better-toml",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "astro-build.astro-vscode",
        "[terraform]": {
          "editor.defaultFormatter": "hashicorp.terraform"
        }
      }
    }
  },
  "remoteUser": "node"
}