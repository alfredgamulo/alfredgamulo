---
/**
 * src/components/CVSSBadge.astro
 *
 * Renders a colored CVSS score badge.
 * Color coding:
 *   CRITICAL / HIGH  → red (#dc2626)
 *   MEDIUM           → orange (#ea580c)
 *   LOW / NONE       → green (#16a34a)
 *
 * Implements T020.
 */

export type CvssSeverity = "CRITICAL" | "HIGH" | "MEDIUM" | "LOW" | "NONE";

export interface Props {
    score: number;
    severity: CvssSeverity;
}

const { score, severity } = Astro.props;

const colorMap: Record<CvssSeverity, string> = {
    CRITICAL: "#dc2626",
    HIGH: "#dc2626",
    MEDIUM: "#ea580c",
    LOW: "#16a34a",
    NONE: "#16a34a",
};

const badgeColor = colorMap[severity];
---

<span
    class="cvss-badge"
    style={`background-color: ${badgeColor};`}
    aria-label={`CVSS score: ${score} — ${severity}`}
>
    <span class="cvss-badge__score">{score.toFixed(1)}</span>
    <span class="cvss-badge__severity">{severity}</span>
</span>

<style>
    .cvss-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4em;
        padding: 4px 10px;
        border-radius: var(--radius-full);
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        font-weight: 700;
        color: #ffffff;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
        letter-spacing: 0.02em;
        vertical-align: middle;
    }

    .cvss-badge__score {
        font-size: var(--text-base);
    }

    .cvss-badge__severity {
        font-size: var(--text-xs);
        opacity: 0.9;
    }
</style>
