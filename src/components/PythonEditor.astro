---
/**
 * src/components/PythonEditor.astro
 *
 * In-browser Python editor using CodeMirror 6 + Pyodide Web Worker.
 * Client-only island — renders only in the browser.
 *
 * Props:
 *   starterCode: Initial Python code shown in the editor.
 *
 * Implements T028.
 */

export interface Props {
    starterCode?: string;
}

const { starterCode = 'print("Hello, World!")' } = Astro.props;
---

<!-- Browser compatibility check (rendered server-side in HTML) -->
<div class="python-editor" data-starter={starterCode} id="python-editor-root">
    <!-- Loading overlay -->
    <div class="editor-overlay" id="editor-loading-overlay">
        <div class="editor-overlay__inner">
            <div class="editor-overlay__spinner" aria-hidden="true"></div>
            <p class="editor-overlay__text" id="loading-text">
                Loading Python runtime…
            </p>
            <button
                class="editor-btn editor-btn--secondary"
                id="retry-btn"
                style="display: none;"
                type="button"
            >
                Loading timed out — Retry
            </button>
        </div>
    </div>

    <!-- Two-panel layout -->
    <div class="editor-panels" id="editor-panels">
        <!-- Left: CodeMirror editor -->
        <div class="editor-panel editor-panel--code">
            <div class="editor-panel__header">
                <span class="editor-panel__label">Python</span>
                <div class="editor-controls">
                    <button
                        class="editor-btn editor-btn--run"
                        id="run-btn"
                        type="button"
                        disabled
                    >
                        ▶ Run
                    </button>
                    <button
                        class="editor-btn editor-btn--secondary"
                        id="reset-btn"
                        type="button"
                    >
                        ↺ Reset
                    </button>
                </div>
            </div>
            <div class="editor-codemirror" id="codemirror-host"></div>
        </div>

        <!-- Right: Output panel -->
        <div class="editor-panel editor-panel--output">
            <div class="editor-panel__header">
                <span class="editor-panel__label">Output</span>
                <button
                    class="editor-btn editor-btn--secondary editor-btn--sm"
                    id="clear-btn"
                    type="button"
                >
                    Clear
                </button>
            </div>
            <pre
                class="editor-output"
                id="output-panel"
                aria-live="polite"
                aria-label="Python output">
            </pre>
        </div>
    </div>
</div>

<!-- No-JS fallback (EC-005) -->
<noscript>
    <div class="noscript-editor-notice">
        <p>
            JavaScript is required to use the Python editor. Please enable
            JavaScript in your browser.
        </p>
    </div>
</noscript>

<script>
    // Read starter code from data attribute (avoids define:vars which prevents ESM/import.meta)
    const _editorRoot = document.getElementById("python-editor-root");
    const _starterCode =
        _editorRoot?.dataset.starter ?? 'print("Hello, World!")';

    // Browser capability check
    if (typeof WebAssembly === "undefined") {
        if (_editorRoot) {
            _editorRoot.innerHTML = `
        <div class="editor-compat-notice">
          <p>⚠️ Your browser does not support WebAssembly, which is required to run the Python editor.
          Please use a modern browser (Chrome 100+, Firefox 100+, Safari 15+, Edge 100+).</p>
        </div>
      `;
        }
    } else {
        initEditor(_starterCode);
    }

    async function initEditor(initialCode) {
        // Dynamic imports — bundled by Astro/Vite
        const { EditorState } = await import("@codemirror/state");
        const { EditorView, lineNumbers, highlightActiveLine, keymap } =
            await import("@codemirror/view");
        const { defaultKeymap, historyKeymap, history } =
            await import("@codemirror/commands");
        const { python } = await import("@codemirror/lang-python");
        const { oneDark } = await import("@codemirror/theme-one-dark");
        const { bracketMatching } = await import("@codemirror/language");

        const host = document.getElementById("codemirror-host");
        const runBtn = document.getElementById("run-btn");
        const resetBtn = document.getElementById("reset-btn");
        const clearBtn = document.getElementById("clear-btn");
        const output = document.getElementById("output-panel");
        const overlay = document.getElementById("editor-loading-overlay");
        const loadingText = document.getElementById("loading-text");
        const retryBtn = document.getElementById("retry-btn");

        // Initialize CodeMirror 6
        const view = new EditorView({
            state: EditorState.create({
                doc: initialCode,
                extensions: [
                    lineNumbers(),
                    highlightActiveLine(),
                    history(),
                    bracketMatching(),
                    python(),
                    oneDark,
                    keymap.of([...defaultKeymap, ...historyKeymap]),
                    EditorView.theme({
                        "&": { height: "100%", fontSize: "14px" },
                        ".cm-scroller": {
                            overflow: "auto",
                            fontFamily: "var(--font-mono, monospace)",
                        },
                    }),
                ],
            }),
            parent: host,
        });

        // Worker management
        let worker = null;
        let timeoutId = null;
        const TIMEOUT_MS = 30_000;

        function createWorker() {
            if (worker) {
                worker.terminate();
            }
            worker = new Worker(
                new URL("../workers/pyodide.worker.ts", import.meta.url),
                { type: "module" },
            );

            // Reset UI to loading state
            overlay.style.display = "flex";
            loadingText.textContent = "Loading Python runtime…";
            retryBtn.style.display = "none";
            runBtn.disabled = true;

            // Timeout after 30s of silence
            clearTimeout(timeoutId);
            timeoutId = setTimeout(() => {
                loadingText.textContent =
                    "Loading is taking longer than expected.";
                retryBtn.style.display = "inline-flex";
            }, TIMEOUT_MS);

            worker.addEventListener("message", (event) => {
                const msg = event.data;
                handleWorkerMessage(msg);
            });

            worker.addEventListener("error", (err) => {
                appendOutput(`Worker error: ${err.message}\n`, "error");
                runBtn.disabled = false;
            });
        }

        function handleWorkerMessage(msg) {
            switch (msg.type) {
                case "ready":
                    clearTimeout(timeoutId);
                    overlay.style.display = "none";
                    runBtn.disabled = false;
                    break;

                case "stdout":
                    appendOutput(msg.text + "\n", "stdout");
                    break;

                case "stderr":
                    appendOutput(msg.text + "\n", "stderr");
                    break;

                case "done":
                    runBtn.disabled = false;
                    break;

                case "error":
                    appendOutput(msg.traceback ?? msg.message, "error");
                    runBtn.disabled = false;
                    break;
            }
        }

        function appendOutput(text, type = "stdout") {
            const span = document.createElement("span");
            span.className = `output-${type}`;
            span.textContent = text;
            output.appendChild(span);
            output.scrollTop = output.scrollHeight;
        }

        // Run button
        runBtn.addEventListener("click", () => {
            const code = view.state.doc.toString();
            output.innerHTML = ""; // Clear on new run
            runBtn.disabled = true;
            worker.postMessage({ type: "run", code });
        });

        // Reset button — restore starter code, clear output, recreate worker
        resetBtn.addEventListener("click", () => {
            // Restore editor content to starter code
            view.dispatch({
                changes: {
                    from: 0,
                    to: view.state.doc.length,
                    insert: initialCode,
                },
            });
            output.innerHTML = "";
            // Recreate worker (implements "reset" behaviour)
            createWorker();
        });

        // Clear button
        clearBtn.addEventListener("click", () => {
            output.innerHTML = "";
        });

        // Retry button
        retryBtn.addEventListener("click", () => {
            createWorker();
        });

        // Start initial worker
        createWorker();
    }
</script>

<style>
    .python-editor {
        position: relative;
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
        height: 100%;
    }

    /* Loading overlay */
    .editor-overlay {
        position: absolute;
        inset: 0;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(13, 17, 23, 0.85);
        backdrop-filter: blur(4px);
    }

    .editor-overlay__inner {
        text-align: center;
    }

    .editor-overlay__spinner {
        width: 40px;
        height: 40px;
        border: 3px solid var(--color-border);
        border-top-color: var(--color-accent);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto var(--space-4);
    }

    @keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .editor-overlay__text {
        color: var(--color-text-muted);
        font-size: var(--text-sm);
        margin: 0 0 var(--space-4);
    }

    /* Two-panel layout */
    .editor-panels {
        flex: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        min-height: 0;
        height: 100%;
        gap: 1px;
        background: var(--color-border);
    }

    @media (max-width: 768px) {
        .editor-panels {
            grid-template-columns: 1fr;
            grid-template-rows: 1fr 1fr;
        }
    }

    .editor-panel {
        display: flex;
        flex-direction: column;
        background: var(--color-bg);
        overflow: hidden;
        min-height: 0;
    }

    .editor-panel__header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--space-2) var(--space-4);
        border-bottom: 1px solid var(--color-border);
        background: var(--color-bg-secondary);
        flex-shrink: 0;
    }

    .editor-panel__label {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .editor-controls {
        display: flex;
        gap: var(--space-2);
    }

    /* Buttons */
    .editor-btn {
        display: inline-flex;
        align-items: center;
        gap: var(--space-1);
        padding: 5px 12px;
        border-radius: var(--radius-md);
        font-size: var(--text-sm);
        font-weight: 500;
        border: 1px solid transparent;
        cursor: pointer;
        transition:
            background 0.15s,
            opacity 0.15s;
    }

    .editor-btn--run {
        background: var(--color-accent);
        color: white;
        border-color: var(--color-accent);
    }

    .editor-btn--run:hover:not(:disabled) {
        background: var(--color-link-hover);
        border-color: var(--color-link-hover);
    }

    .editor-btn--run:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .editor-btn--secondary {
        background: var(--color-bg-tertiary);
        color: var(--color-text);
        border-color: var(--color-border);
    }

    .editor-btn--secondary:hover {
        background: var(--color-bg-secondary);
    }

    .editor-btn--sm {
        padding: 3px 8px;
        font-size: var(--text-xs);
    }

    /* CodeMirror host */
    .editor-codemirror {
        flex: 1;
        overflow: hidden;
        min-height: 0;
    }

    .editor-codemirror :global(.cm-editor) {
        height: 100%;
    }

    /* Output panel */
    .editor-output {
        flex: 1;
        overflow-y: auto;
        margin: 0;
        padding: var(--space-4);
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        line-height: var(--leading-relaxed);
        background: var(--color-bg);
        border: none;
        border-radius: 0;
        white-space: pre-wrap;
        word-break: break-word;
    }

    :global(.output-stdout) {
        color: var(--color-text);
    }

    :global(.output-stderr) {
        color: #f97316;
    }

    :global(.output-error) {
        color: #dc2626;
    }

    /* Compat notice */
    .editor-compat-notice,
    .noscript-editor-notice {
        padding: var(--space-8);
        max-width: 600px;
        margin: 0 auto;
        color: var(--color-text-muted);
        font-size: var(--text-base);
        text-align: center;
    }
</style>
