---
/**
 * src/pages/notes/[slug].astro
 *
 * Dynamic route for note pages (pageType === "note").
 * Renders each entry with NoteLayout.
 */

import { getCollection, render } from "astro:content";
import NoteLayout from "@layouts/NoteLayout.astro";

export async function getStaticPaths() {
    const entries = await getCollection(
        "garden",
        ({ data }) => !data.draft && data.pageType === "note",
    );

    return entries.map((entry) => {
        // entry.id in Astro 6 Content Layer is like "notes/example-note" (no extension)
        const parts = entry.id.split("/");
        const slug = parts[parts.length - 1];
        return {
            params: { slug },
            props: { entry },
        };
    });
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const siteUrl = "https://alfredgamulo.com";
const canonical =
    entry.data.canonical ?? `${siteUrl}/notes/${Astro.params.slug}.html`;
---

<NoteLayout
    title={entry.data.title}
    description={entry.data.description}
    canonical={canonical}
    ogImage={entry.data.ogImage}
    date={entry.data.date}
    tags={entry.data.tags}
>
    <Content />
</NoteLayout>
