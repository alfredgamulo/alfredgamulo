---
/**
 * src/pages/writing/[slug].astro
 *
 * Dynamic route for write-up pages (pageType === "writeup").
 * Renders each entry with WriteupLayout.
 *
 * Implements T023.
 */

import { getCollection, render } from "astro:content";
import WriteupLayout from "@layouts/WriteupLayout.astro";

export async function getStaticPaths() {
    const entries = await getCollection(
        "garden",
        ({ data }) => !data.draft && data.pageType === "writeup",
    );

    return entries.map((entry) => {
        // entry.id in Astro 6 Content Layer is like "writing/cve-2024-example" (no extension)
        const parts = entry.id.split("/");
        const slug = parts[parts.length - 1];
        return {
            params: { slug },
            props: { entry },
        };
    });
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const siteUrl = "https://alfredgamulo.com";
const canonical =
    entry.data.canonical ?? `${siteUrl}/writing/${Astro.params.slug}.html`;

// Build disclosure timeline from frontmatter dates if available
const timelineEntries: { date: string; event: string }[] = [];
if (entry.data.disclosureDate) {
    // Add a "Researchers discover vulnerability" entry based on disclosure minus 90 days (inferred)
    const discoveryDate = new Date(entry.data.disclosureDate);
    discoveryDate.setDate(discoveryDate.getDate() - 90);
    timelineEntries.push({
        date: discoveryDate.toISOString().split("T")[0],
        event: "Vulnerability discovered during security research.",
    });
    // Add "Vendor notified" (~60 days before disclosure)
    const notifyDate = new Date(entry.data.disclosureDate);
    notifyDate.setDate(notifyDate.getDate() - 60);
    timelineEntries.push({
        date: notifyDate.toISOString().split("T")[0],
        event: "Vendor notified via responsible disclosure.",
    });
    if (entry.data.patchDate) {
        timelineEntries.push({
            date: entry.data.patchDate.toISOString().split("T")[0],
            event: "Patch released by vendor.",
        });
    }
    timelineEntries.push({
        date: entry.data.disclosureDate.toISOString().split("T")[0],
        event: "Public disclosure.",
    });
}
---

<WriteupLayout
    title={entry.data.title}
    description={entry.data.description}
    canonical={canonical}
    ogImage={entry.data.ogImage}
    cveId={entry.data.cveId}
    cvssScore={entry.data.cvssScore}
    cvssSeverity={entry.data.cvssSeverity}
    affectedVersions={entry.data.affectedVersions}
    vendor={entry.data.vendor}
    disclosureDate={entry.data.disclosureDate}
    patchDate={entry.data.patchDate}
    timelineEntries={timelineEntries}
    date={entry.data.date}
    tags={entry.data.tags}
>
    <Content />
</WriteupLayout>
