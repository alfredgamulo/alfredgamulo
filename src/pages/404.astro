---
/**
 * src/pages/404.astro
 *
 * Custom 404 error page.
 * CloudFront custom error: set ErrorCode 404 → ResponsePage /404.html,
 * ResponseCode 404 in the CloudFront distribution error pages settings.
 *
 * Implements T034.
 */

import BaseLayout from "@layouts/BaseLayout.astro";

const siteUrl = "https://alfredgamulo.com";
---

<BaseLayout
    title="Page Not Found"
    description="The page you are looking for does not exist."
    canonical={`${siteUrl}/404`}
>
    <div class="not-found">
        <div class="not-found__code" aria-hidden="true">404</div>
        <h1 class="not-found__title">Page not found</h1>
        <p class="not-found__message">
            The page you're looking for doesn't exist or may have moved.
        </p>
        <a href="/" class="not-found__link">← Back to the garden</a>
    </div>
</BaseLayout>

<style>
    .not-found {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 100px);
        text-align: center;
        padding: var(--space-8);
    }

    .not-found__code {
        font-family: var(--font-mono);
        font-size: 8rem;
        font-weight: 700;
        color: var(--color-border);
        line-height: 1;
        margin-bottom: var(--space-4);
        user-select: none;
    }

    .not-found__title {
        font-size: var(--text-3xl);
        font-weight: 700;
        margin: 0 0 var(--space-4);
        color: var(--color-text);
    }

    .not-found__message {
        font-size: var(--text-lg);
        color: var(--color-text-muted);
        margin: 0 0 var(--space-8);
        max-width: 400px;
    }

    .not-found__link {
        display: inline-flex;
        align-items: center;
        padding: var(--space-3) var(--space-6);
        background: var(--color-accent);
        color: white;
        text-decoration: none;
        border-radius: var(--radius-md);
        font-weight: 500;
        transition: background 0.15s;
    }

    .not-found__link:hover {
        background: var(--color-link-hover);
        color: white;
    }
</style>
